---

<section id="experience" class="py-16">
  <h2 class="text-4xl text-center font-bold mb-8 text-blue-600 dark:text-blue-400 items-center gap-2">
    Experience
  </h2>
  
  <div class="flex flex-col md:flex-row gap-4 md:gap-8">
    <div class="flex md:flex-col overflow-x-auto border-b md:border-b-0 md:border-l border-gray-200 dark:border-gray-800 md:min-w-[200px] z-10">
      {experiences.map((exp, index) => (
        <button
          class={`tab-btn text-left px-4 py-3 text-sm font-medium transition-all duration-200 whitespace-nowrap md:whitespace-normal
            ${index === 0 
              ? 'text-blue-600 dark:text-blue-400 bg-blue-50/50 dark:bg-blue-900/20 border-b-2 md:border-b-0 md:border-l-2 border-blue-600 dark:border-blue-400 md:-ml-[1px]' 
              : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800/50 border-b-2 md:border-b-0 md:border-l-2 border-transparent md:-ml-[1px] hover:text-blue-600 dark:hover:text-blue-400'
            }`}
          data-target={exp.id}
        >
          {exp.tabTitle}
        </button>
      ))}
    </div>

    <div class="flex-1 relative min-h-[250px] mt-4 md:mt-0">
      {experiences.map((exp, index) => (
        <div
          id={exp.id}
          class={`tab-content transition-opacity duration-300 absolute top-0 left-0 w-full 
            ${index === 0 ? 'opacity-100 z-10 relative' : 'opacity-0 z-0 invisible absolute'}`}
        >
          <h3 class="text-xl font-bold text-gray-900 dark:text-white" aria-label={exp.jobTitle}>
            {exp.jobTitle} 
            <span class="text-blue-600 dark:text-blue-400">
              @ <a href={exp.companyUrl} target="_blank" rel="noopener noreferrer" class="hover:underline" aria-label={exp.company}>{exp.company}</a>
            </span>
          </h3>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1 mb-4 font-mono">{exp.date}</p>
          
          <ul class="list-none space-y-3 text-gray-700 dark:text-gray-300">
            {exp.description.map(item => (
              <li class="flex gap-3 items-start">
                <span class="text-blue-600 dark:text-blue-400 mt-1 text-sm">▹</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Tab system
  const setupTabs = () => {
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        // Resetting all tabs
        tabs.forEach(t => {
          t.className = "tab-btn text-left px-4 py-3 text-sm font-medium transition-all duration-200 whitespace-nowrap md:whitespace-normal text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800/50 border-b-2 md:border-b-0 md:border-l-2 border-transparent md:-ml-[1px] hover:text-blue-600 dark:hover:text-blue-400";
        });

        // Highlighting the active tab
        tab.className = "tab-btn text-left px-4 py-3 text-sm font-medium transition-all duration-200 whitespace-nowrap md:whitespace-normal text-blue-600 dark:text-blue-400 bg-blue-50/50 dark:bg-blue-900/20 border-b-2 md:border-b-0 md:border-l-2 border-blue-600 dark:border-blue-400 md:-ml-[1px]";

        // Hiding all contents
        contents.forEach(c => {
          c.className = "tab-content transition-opacity duration-300 absolute top-0 left-0 w-full opacity-0 z-0 invisible";
        });

        // Showing the targeted content
        const targetId = tab.getAttribute('data-target');
        // @ts-ignore - This is to ignore the fact that getElementById might return null, but it wont.
        const targetContent = document.getElementById(targetId);
        if (targetContent) {
          targetContent.className = "tab-content transition-opacity duration-300 absolute top-0 left-0 w-full opacity-100 z-10 relative";
        }
      });
    });
  };

  setupTabs();
</script>
---
import { Image } from 'astro:assets';

const projects = [
  {
    image: "/images/projects/profile.png",
    tags: ["Astro", "Tailwind", "JavaScript"],
    title: "This website",
    description: "A fully responsive personal portfolio and blog website made with Astro and Tailwind CSS, deployed with GitHub Pages.",
    githubUrl: "https://github.com/Okaneeee/okaneeee.github.io",
    demoUrl: "https://okaneeee.github.io"
  },
  {
    image: "/images/projects/chatbot.png",
    tags: ["Discord", "Neural Networks", "Python"],
    title: "Discord Chatbot",
    description: "A small-scale neural networks chatbot in Python linked to Discord.",
    githubUrl: "https://github.com/Okaneeee",
    demoUrl: "https://github.com/Okaneeee/SWCodes"
  },
  {
    image: "/images/projects/swcodes.png",
    tags: ["Discord", "CI/CD", "Python"],
    title: "SW Codes",
    description: "SW Codes is a discord bot to facilitate the use of codes for the mobile game Summoners War",
    githubUrl: "https://github.com/Okaneeee/SWCodes",
    demoUrl: "" // If left empty, the demo button will not be displayed
  }
];
---

<section id="projects" class="py-16">
  <h2 class="text-3xl font-bold mb-8 text-gray-900 dark:text-white flex items-center gap-2">
    <span class="text-blue-600 dark:text-blue-400 text-xl">04.</span> Featured Projects
  </h2>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {projects.map((project) => (
      <div class="flex flex-col bg-white dark:bg-gray-900 rounded-lg overflow-hidden border border-gray-200 dark:border-gray-800 transition-transform hover:-translate-y-1 hover:shadow-lg">
        
        <Image src={project.image}
          alt={project.title}
          width={1920} height={1080}
          loading={'lazy'}
          class="w-full object-cover"
        />
        
        <div class="p-5 flex-grow flex flex-col">
          <div class="flex flex-wrap gap-2 mb-3">
            {project.tags.map(tag => (
              <span class="text-xs font-mono text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30 px-2 py-1 rounded">
                {tag}
              </span>
            ))}
          </div>
          
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">{project.title}</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm mb-6 flex-grow">{project.description}</p>
          
          <div class="mt-auto pt-4 border-t border-gray-100 dark:border-gray-800 flex justify-between items-center">
            
            <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-gray-900 dark:hover:text-white transition-colors" aria-label="GitHub">
              <svg class="w-7 h-7 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"></path></svg>
            </a>
            
            {project.demoUrl !== "" && (
              <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" class="text-xs font-medium bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-900 dark:text-white px-3 py-1.5 rounded transition-colors">
                Demo
              </a>
            )}
            
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
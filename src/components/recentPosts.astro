---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

// Getting both collections
const allProjects = await getCollection('projects');
const allGames = await getCollection('games');

// Formatting the items to add the correct URL (projects/ or games/)
const formattedProjects = allProjects.map(p => ({ ...p, url: `/projects/${p.slug}`, category: 'Project' }));
const formattedGames = allGames.map(g => ({ ...g, url: `/games/${g.slug}`, category: 'Game' }));

// Merging, sorting by date (newest first), and slicing to keep only the top 3
const recentPosts = [...formattedProjects, ...formattedGames]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
};
---

<section class="border-t border-gray-200 dark:border-gray-800 pt-12 mt-8">
  <h2 class="text-3xl font-serif font-bold text-slate-800 dark:text-white mb-8 text-center">Recent Updates</h2>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {recentPosts.map((post) => (
      <div class="flex flex-col bg-white dark:bg-gray-900 rounded-xl overflow-hidden shadow-sm hover:shadow-lg border border-gray-200 dark:border-gray-800 transition-all duration-300 h-full group">
        
        <a href={post.url} class="block overflow-hidden border-b border-gray-100 dark:border-gray-800 relative">
          <Image
            src={post.data.image} 
            alt={post.data.title} 
            width={800} height={450}
            loading={"lazy"}
            class="w-full h-40 object-cover transition-transform duration-500 group-hover:scale-105"
          />
          {post.data.badgeImage && (
            <div class="absolute bottom-0 right-0 p-1.5 rounded-lg shadow-lg z-10 transition-transform duration-300 group-hover:scale-110">
              <Image 
                src={post.data.badgeImage} 
                alt="Badge" 
                width={10} height={10}
                loading={"lazy"}
                class="w-10 h-10 object-contain"
              />
            </div>
          )}
        </a>
        
        <div class="p-5 flex-grow flex flex-col">
          <span class="text-xs font-sans font-bold text-blue-500 mb-2 uppercase tracking-wider">{post.category}</span>
          <a href={post.url}>
            <h3 class="text-xl font-serif font-bold text-slate-800 dark:text-white mb-2 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{post.data.title}</h3>
          </a>
          <p class="text-slate-600 dark:text-gray-400 text-sm leading-relaxed flex-grow line-clamp-2 mb-4">
            {post.data.description}
          </p>
          <div class="mt-auto pt-4 border-t border-gray-100 dark:border-gray-800 flex justify-between items-center">
            <span class="text-xs font-sans font-medium text-slate-500 dark:text-gray-400">{formatDate(post.data.date)}</span>
            <a href={post.url} class="text-xs font-sans font-medium px-3 py-1 rounded border border-gray-200 dark:border-gray-700 text-slate-700 dark:text-gray-300 hover:bg-[#EDF3F9] hover:border-blue-200 hover:text-blue-600 dark:hover:bg-[#011336] dark:hover:border-[#1e3a8a]/50 dark:hover:text-blue-400 transition-all">Read</a>
          </div>
        </div>

      </div>
    ))}
  </div>
</section>
---
import BaseLayout from '../../layouts/baseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const games = await getCollection('games');
  return games.map(game => ({
    params: { slug: game.slug },
    props: { game },
  }));
}

const { game } = Astro.props;
const { Content, headings } = await game.render();

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<BaseLayout title={`${game.data.title} | Anatole`}>
  
  <!-- Back button -->
  <div class="max-w-[1400px] mx-auto px-4 pt-8">
    <button onclick="history.back()" class="inline-flex items-center gap-2 text-slate-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400 transition-all duration-300 hover:-translate-y-1 font-medium">
      &larr; Back
    </button>
  </div>

  <!-- Content -->
  <article class="max-w-[1600px] mx-auto px-4 py-8 md:py-8">
    
    <!-- Title + Metadata -->
    <header class="mb-10 text-center max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold font-serif text-slate-800 dark:text-white mb-4">{game.data.title}</h1>
      <p class="text-slate-500 dark:text-gray-400 font-sans font-medium">
        Anatole | {formatDate(game.data.date)}
      </p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      <!-- Tags Sidebar -->
      <aside class="hidden lg:block lg:col-span-2 sticky top-32">
        <h3 class="text-lg font-serif font-bold text-slate-800 dark:text-white mb-4">Tags</h3>
        <div class="flex flex-col gap-2">
          {game.data.tags.map(tag => (
            <span class="text-sm font-sans font-medium text-slate-600 dark:text-gray-300 bg-gray-100 dark:bg-gray-800/80 border border-gray-200 dark:border-gray-700 px-3 py-1.5 rounded-md w-fit">
              {tag}
            </span>
          ))}
        </div>
      </aside>

      <div class="lg:col-span-7">
        <Image
          src={game.data.image}
          alt={game.data.title}
          width={1920} height={1080}
          loading={"eager"}
          class="w-full h-auto rounded-xl shadow-md border border-gray-100 dark:border-gray-800 mb-10 object-cover aspect-video"
        />
        
        <div class="markdown-content text-lg leading-relaxed text-slate-700 dark:text-gray-300 space-y-6">
          <Content />
        </div>

        <!-- Action buttons -->
        {(game.data.githubUrl || game.data.demoUrl) && (
          <div class="mt-16 pt-8 border-t border-gray-200 dark:border-gray-800 flex flex-col sm:flex-row gap-6 justify-center">
            
            {game.data.githubUrl && (
              <a href={game.data.githubUrl} target="_blank" rel="noopener noreferrer" class="group flex items-center justify-center gap-2 px-8 py-3 bg-[#EDF3F9] dark:bg-[#011336] text-slate-800 dark:text-gray-200 border border-blue-100 dark:border-[#1e3a8a]/30 hover:bg-blue-600 hover:border-blue-600 hover:text-white dark:hover:bg-blue-600 dark:hover:border-blue-600 dark:hover:text-white transition-all duration-300 font-medium shadow-md hover:shadow-lg hover:-translate-y-1 rounded-lg">
                <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"></path></svg>
                View on GitHub
              </a>
            )}
            
            {game.data.demoUrl && (
              <a href={game.data.demoUrl} target="_blank" rel="noopener noreferrer" class="group flex items-center justify-center gap-2 px-8 py-3 bg-[#EDF3F9] dark:bg-[#011336] text-slate-800 dark:text-gray-200 border border-blue-100 dark:border-[#1e3a8a]/30 hover:bg-blue-600 hover:border-blue-600 hover:text-white dark:hover:bg-blue-600 dark:hover:border-blue-600 dark:hover:text-white transition-all duration-300 font-medium shadow-md hover:shadow-lg hover:-translate-y-1 rounded-lg">
                View Live Demo
                <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
              </a>
            )}
          </div>
        )}
      </div>

      <!-- Table of Contents -->
      <aside class="hidden lg:block lg:col-span-3 sticky top-32">
        <div class="bg-[#f8f9fa] dark:bg-[#011336]/30 border border-gray-200 dark:border-gray-800 rounded-xl p-6">
          <h3 class="text-lg font-serif font-bold text-slate-800 dark:text-white mb-4">Table of Contents</h3>
          {headings.length > 0 ? (
            <ul class="space-y-3 text-sm font-medium">
              {headings.map((heading) => (
                <li class={`leading-snug ${heading.depth === 2 ? 'ml-0' : heading.depth === 3 ? 'ml-3 text-slate-500' : 'ml-6 text-slate-400'}`}>
                  <a href={`#${heading.slug}`} class="text-slate-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-sm text-slate-500 dark:text-gray-500 italic">No table of contents available.</p>
          )}
        </div>
      </aside>
    </div>

    <!-- Mobile Table of Contents -->
    <div class="lg:hidden mt-12 pt-8 border-t border-gray-200 dark:border-gray-800 space-y-10">
      {headings.length > 0 && (
        <div class="bg-[#f8f9fa] dark:bg-[#011336]/30 border border-gray-200 dark:border-gray-800 rounded-xl p-6">
          <h3 class="text-lg font-serif font-bold text-slate-800 dark:text-white mb-4">Table of Contents</h3>
          <ul class="space-y-3 text-sm font-medium">
            {headings.map((heading) => (
              <li class={`leading-snug ${heading.depth === 2 ? 'ml-0' : heading.depth === 3 ? 'ml-3' : 'ml-6'}`}>
                <a href={`#${heading.slug}`} class="text-slate-600 dark:text-gray-400 hover:text-blue-600 transition-colors">{heading.text}</a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Tags -->
      <div>
        <h3 class="text-lg font-serif font-bold text-slate-800 dark:text-white mb-4">Tags</h3>
        <div class="flex flex-wrap gap-2">
          {game.data.tags.map(tag => (
            <span class="text-sm font-sans font-medium text-slate-600 dark:text-gray-300 bg-gray-100 dark:bg-gray-800/80 border border-gray-200 dark:border-gray-700 px-3 py-1.5 rounded-md">
              {tag}
            </span>
          ))}
        </div>
      </div>
    </div>

  </article>
</BaseLayout>
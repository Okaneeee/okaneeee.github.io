---
import BaseLayout from '../layouts/baseLayout.astro';
import Experience from '../components/experience.astro';
import Education from '../components/education.astro';
---

<BaseLayout title="Anatole | Résumé">
  
  <div class="py-12 md:py-20 max-w-4xl mx-auto text-center border-b border-gray-200 dark:border-gray-800 mb-8">
    <h1 class="text-4xl md:text-5xl font-bold text-slate-800 dark:text-white mb-6">My Résumé</h1>
    <p class="text-lg text-slate-600 dark:text-gray-400 leading-relaxed">
      A comprehensive overview of my academic background and professional experience. </br>
      Discover the journey and the skills that shaped my profile as a software and game developer.
    </p>
  </div>
  
  <Experience />
  <Education />
  
  <div class="mt-14 flex flex-col sm:flex-row justify-center items-center gap-6">
    
    <a href="/projects" class="group flex items-center justify-center gap-2 px-8 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-all duration-300 font-medium shadow-md hover:shadow-lg hover:-translate-y-1">
      See more Projects
      <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
      </svg>
    </a>
    
    <a href="/games" class="group flex items-center justify-center gap-2 px-8 py-3 bg-slate-800 dark:bg-slate-200 text-white dark:text-slate-900 rounded-lg hover:bg-slate-900 dark:hover:bg-white transition-all duration-300 font-medium shadow-md hover:shadow-lg hover:-translate-y-1">
      See more Games
      <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
      </svg>
    </a>
    
  </div>

</BaseLayout>